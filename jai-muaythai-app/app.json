{
  "expo": {
    "name": "jai-muaythai-app",
    "slug": "jai-muaythai-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jaimuaythai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Jai Muay Thai to access your camera for profile photos and document scanning.",
        "NSPhotoLibraryUsageDescription": "Allow Jai Muay Thai to access your photo library to upload profile photos.",
        "NSPhotoLibraryAddUsageDescription": "Allow Jai Muay Thai to save photos to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jaimuaythai.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0096FF"
        }
      ]
    ]
  }
}
